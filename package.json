{
  "name": "escort-radar-fun",
  "private": true,
  "version": "0.1.0",
  "workspaces": [
    "Front",
    "Back"
  ],
  "scripts": {
    "dev": "npm run dev -w Front",
    "dev:frontend": "npm run dev -w Front",
    "dev:backend": "npm run dev -w Back",
